@{
    var currentUser = (User?.Identity?.Name) ?? (Environment.UserDomainName + "\\" + Environment.UserName);
    var globalQ = Context.Request.Path.StartsWithSegments("/Search") ? Context.Request.Query["q"].ToString() : "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Inventory</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav>
            <a class="brand" asp-page="/Index">Inventory</a>
            <a asp-page="/Devices/Index">Devices</a>
            <a asp-page="/Users/Index">Users</a>
            <a asp-page="/Sites/Index">Sites</a>
            <a asp-page="/Import/Index">Import</a>
            <a asp-page="/Settings/Index">Settings</a>
            <form method="get" action="/Search" class="global-search" autocomplete="off">
                <input type="text" name="q" value="@globalQ" placeholder="Search everything..." autocomplete="off" />
            </form>
            <span class="who">@currentUser</span>
        </nav>
    </header>
    <main>
        @if (TempData["Message"] is string msg)
        {
            <div class="flash">@msg</div>
        }
        @RenderBody()
    </main>
    <script src="~/js/site.js"></script>
</body>
</html>
