@page "{id:int}"
@model Inventory.Web.Pages.Sites.EditModel
@{
    ViewData["Title"] = "Edit Site";
}

<h1>Edit Site</h1>

<form method="post" class="card">
    <input type="hidden" asp-for="Input.Id" />
    <div asp-validation-summary="All" class="error"></div>
    <label>Name</label>
    <input type="text" asp-for="Input.Name" />
    <label>Address</label>
    <input type="text" asp-for="Input.Address" />
    <div class="actions">
        <button type="submit">Save</button>
        <a class="button secondary" asp-page="Index">Cancel</a>
        <button type="submit" asp-page-handler="Delete" formnovalidate class="danger"
                onclick="return confirm('Delete this site? Devices and users at this site will be unlinked from it.');">Delete</button>
    </div>
</form>
