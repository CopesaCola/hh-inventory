@page
@model Inventory.Web.Pages.Sites.IndexModel
@{
    ViewData["Title"] = "Sites";
}

<h1>Sites</h1>

<form method="get" class="card" style="padding:0.8rem 1rem;" autocomplete="off">
    <div class="search-row">
        <div class="entity-suggest" data-search-scope="sites">
            <input type="text" name="q" value="@Model.Query" placeholder="Name or address..." autocomplete="off" />
        </div>
        <button type="submit">Search</button>
        <a class="button secondary" asp-page="Index">Reset</a>
        <span class="muted">@Model.Sites.Count site(s)</span>
    </div>
</form>

<div class="toolbar">
    <a class="button" asp-page="Create">+ Add Site</a>
    <a class="button secondary" style="margin-left:auto;"
       asp-page="Index" asp-page-handler="Export"
       asp-route-q="@Model.Query">Export CSV</a>
</div>

@if (Model.Sites.Count == 0)
{
    <p class="muted">No sites match.</p>
}
else
{
    <table>
        <thead><tr><th>Name</th><th>Address</th><th>Users</th><th>Devices</th></tr></thead>
        <tbody>
        @foreach (var s in Model.Sites)
        {
            <tr data-href="@Url.Page("Details", new { id = s.Id })">
                <td><a asp-page="Details" asp-route-id="@s.Id">@s.Name</a></td>
                <td>@s.Address</td>
                <td>@s.Users.Count</td>
                <td>@s.Devices.Count</td>
            </tr>
        }
        </tbody>
    </table>
}
