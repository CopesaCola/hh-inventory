@page
@model Inventory.Web.Pages.Devices.CreateModel
@inject Inventory.Web.Services.ILabelService L
@{
    ViewData["Title"] = "Add Device";
    var E = Inventory.Web.Models.CustomFieldEntityType.Device;
}

<h1>Add Device</h1>

<form method="post" class="card">
    <div asp-validation-summary="All" class="error"></div>
    <div class="row-2">
        <div>
            <label>@L.Get(E, "DeviceType", "Device Type")</label>
            <select asp-for="Input.DeviceTypeId">
                <option value="">(none)</option>
                @foreach (var t in Model.DeviceTypes)
                {
                    <option value="@t.Id">@t.Name</option>
                }
            </select>
            <span asp-validation-for="Input.DeviceTypeId" class="error"></span>
        </div>
        <div>
            <label>@L.Get(E, "Model", "Model")</label>
            <input type="text" asp-for="Input.Model" />
            <span asp-validation-for="Input.Model" class="error"></span>
        </div>
        <div>
            <label>@L.Get(E, "SerialNumber", "Serial Number")</label>
            <input type="text" asp-for="Input.SerialNumber" />
        </div>
        <div>
            <label>@L.Get(E, "AssetTag", "Asset Tag")</label>
            <input type="text" asp-for="Input.AssetTag" />
        </div>
        <div>
            <label>@L.Get(E, "Status", "Status")</label>
            <select asp-for="Input.StatusId">
                @foreach (var s in Model.Statuses)
                {
                    <option value="@s.Id">@s.Name</option>
                }
            </select>
        </div>
        <div>
            <label>@L.Get(E, "LocationWithinSite", "Location Within Site")</label>
            <input type="text" asp-for="Input.LocationWithinSite" placeholder="Room 204, Desk 3" />
        </div>
        <div>
            <label>@L.Get(E, "WindowsVersion", "Windows Version")</label>
            <input type="text" asp-for="Input.WindowsVersion" placeholder="11, 10..." />
        </div>
        <div>
            <label>@L.Get(E, "IsGrantFunded", "Grant or Dept Funded")</label>
            <select asp-for="Input.IsGrantFunded">
                <option value="false">No</option>
                <option value="true">Yes</option>
            </select>
        </div>
        <div>
            <label>@L.Get(E, "AssignedUser", "Assigned User")</label>
            <div class="combobox" data-search-url="/api/users/search">
                <input type="text" class="combobox-input" autocomplete="off"
                       value="@Model.AssignedUserName" placeholder="Type to search users..." />
                <input type="hidden" asp-for="Input.AssignedUserId" class="combobox-id" />
                <span class="combobox-clear" title="Clear">&times;</span>
                <div class="combobox-results"></div>
            </div>
        </div>
        <div>
            <label>@L.Get(E, "Site", "Site")</label>
            <select asp-for="Input.SiteId">
                <option value="">(none)</option>
                @foreach (var s in Model.Sites)
                {
                    <option value="@s.Id">@s.Name</option>
                }
            </select>
        </div>
    </div>

    <partial name="_CustomFieldsForm" model="@((Model.CustomDefs, Model.CustomValues))" />

    <div class="actions">
        <button type="submit">Save</button>
        <a class="button secondary" asp-page="Index">Cancel</a>
    </div>
</form>
